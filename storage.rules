rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // Forum post images - authenticated users can upload, all can view
    match /forum/{postId}/{allFiles=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && 
                      request.resource.size < 5000000 && // 5MB max
                      request.resource.contentType.matches('image/.*');
    }
    
    // Journal entry attachments - private to authenticated user
    match /journal/{userId}/{allFiles=**} {
      allow read, write: if request.auth != null && 
                           request.auth.uid == userId &&
                           request.resource.size < 10000000; // 10MB max
    }
    
    // User profile images - public read, authenticated write
    match /users/{userId}/profile/{fileName} {
      allow read: if true;
      allow write: if request.auth != null && 
                      request.auth.uid == userId &&
                      request.resource.contentType.matches('image/.*') &&
                      request.resource.size < 3000000; // 3MB max
    }
    
    // Deny everything else by default
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}